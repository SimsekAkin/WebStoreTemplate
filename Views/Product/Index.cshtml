@model List<WebStore.Models.Product>

@{
    // Page title for product management listing.
    ViewData["Title"] = "Product Management";
}

<div class="container py-4">
    @* Show one-time result message after add/edit/delete actions. *@
    @if (TempData["InfoMessage"] is string infoMessage)
    {
        <div class="alert alert-info" role="alert" data-auto-dismiss="3000">
            @infoMessage
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Product Management</h1>
        <a asp-controller="Product" asp-action="Upsert" class="btn btn-primary">Add Product</a>
    </div>

    @* Empty-state message when there are no products in database. *@
    @if (!Model.Any())
    {
        <div class="alert alert-warning" role="alert" data-auto-dismiss="3000">
            No products found.
        </div>
    }
    else
    {
        @* Main management table with image preview and CRUD actions. *@
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th style="width: 90px;">Image</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @* Render one row per product. *@
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td>
                                @* Product image, fallback to default image when URL is empty. *@
                                @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" style="width: 64px; height: 64px; object-fit: cover;" class="rounded" />
                                }
                                else
                                {
                                    <img src="~/image/default.jpg" alt="Default product image" style="width: 64px; height: 64px; object-fit: cover;" class="rounded" />
                                }
                            </td>
                            <td>@product.Name</td>
                            <td>@($"€{product.Price:0.00}")</td>
                            <td>@product.Stock</td>
                            <td>
                                @* Edit, details, and delete actions for each product. *@
                                <div class="d-flex gap-2">
                                    <a asp-controller="Product"
                                       asp-action="Upsert"
                                       asp-route-id="@product.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        Edit
                                    </a>

                                    <a asp-controller="Home"
                                       asp-action="Details"
                                       asp-route-id="@product.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Details
                                    </a>

                                    <form asp-controller="Product"
                                          asp-action="Delete"
                                          asp-route-id="@product.Id"
                                          method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this product?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
