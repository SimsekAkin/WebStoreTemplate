@model WebStore.Models.Product

@{
    // Use a single form for both Add and Edit modes.
    var formMode = ViewData["FormMode"]?.ToString() ?? (Model.Id == 0 ? "Add" : "Edit");
    var pageTitle = formMode == "Add" ? "Add Product" : "Edit Product";
    ViewData["Title"] = pageTitle;
}

<div class="container py-4">
    @* Header with context-aware title and back navigation. *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">@pageTitle</h1>
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            @* Main product form posted to Upsert action. *@
            <form asp-action="Upsert" method="post">
                @Html.AntiForgeryToken()
                @* Keep product id when editing. *@
                <input asp-for="Id" type="hidden" />

                @* Display model-level validation errors. *@
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @* Basic product fields. *@
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                @* Numeric fields grouped in one responsive row. *@
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Stock" class="form-label"></label>
                        <input asp-for="Stock" class="form-control" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>
                </div>

                @* Optional image URL for product card and details preview. *@
                <div class="mt-3 mb-4">
                    <label asp-for="ImageUrl" class="form-label"></label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                </div>

                @* Submit caption changes by mode; cancel returns to list page. *@
                <button type="submit" class="btn btn-primary">
                    @(formMode == "Add" ? "Create" : "Save Changes")
                </button>
                <a asp-controller="Product" asp-action="Index" class="btn btn-link">Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @* Enables client-side validation for this form. *@
    <partial name="_ValidationScriptsPartial" />
}
