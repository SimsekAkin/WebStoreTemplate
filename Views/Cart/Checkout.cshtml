@model List<WebStore.Models.CartItem>

@{
    // Page title and computed cart total for checkout summary.
    ViewData["Title"] = "Checkout";
    var total = Model.Sum(x => x.Price * x.Quantity);
}

<div class="container py-4">
    @* Header row with page title and quick navigation back to cart. *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Checkout</h1>
        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">Back to Cart</a>
    </div>

    @* Order summary card: all line items currently in session cart. *@
    <div class="card shadow-sm mb-3">
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Line Total</th>
                    </tr>
                </thead>
                <tbody>
                    @* Render one row per cart item. *@
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td class="text-end">@($"€{item.Price:0.00}")</td>
                            <td class="text-end">@item.Quantity</td>
                            <td class="text-end">@($"€{(item.Price * item.Quantity):0.00}")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    @* Final amount to be paid. *@
                    <tr>
                        <th colspan="3" class="text-end">Grand Total</th>
                        <th class="text-end">@($"€{total:0.00}")</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    @* Exam template note: add address and payment fields here when needed. *@


</div>
